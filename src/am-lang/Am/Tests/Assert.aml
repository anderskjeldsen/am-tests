namespace Am.Tests
{
    class Assert {
        import Am.Lang
        
        static fun assertEquals(expected: Any, actual: Any) {
            if (expected != actual) {
                throw new AssertException("Assertion failed: expected '$expected', got '$actual'")
            }
        }

        #require floatingPoint
        static fun assertDoubleCloseEnough(expected: Double, actual: Double) {
            var diff = actual - expected
            if (diff < 0.0) {
                diff = -diff
            }
            if (diff > 0.00001) {
                throw new AssertException("Assertion failed: expected '$expected' close enough, got '$actual'")
            }
        }

        #require floatingPoint
        static fun assertFloatCloseEnough(expected: Float, actual: Float) {
            var diff = actual - expected
            if (diff < 0.0F) {
                diff = -diff
            }
            if (diff > 0.00001F) {
                throw new AssertException("Assertion failed: expected '$expected' close enough, got '$actual'")
            }
        }

        #require floatingPoint
        static fun assertDoubleClose(expected: Double, actual: Double, epsilon: Double) {
            var diff = actual - expected
            if (diff < 0.0) {
                diff = -diff
            }
            if (diff > epsilon) {
                throw new AssertException("Assertion failed: expected '$expected' +/- '$epsilon', got '$actual'")
            }
        }

        #require floatingPoint
        static fun assertFloatClose(expected: Float, actual: Float, epsilon: Float) {
            var diff = actual - expected
            if (diff < 0.0F) {
                diff = -diff
            }
            if (diff > epsilon) {
                throw new AssertException("Assertion failed: expected '$expected' +/- '$epsilon', got '$actual'")
            }
        }

        static fun assertTrue(condition: Bool) {
            if (!condition) {
                throw new AssertException("Assertion failed: condition is false")
            }
        }

        static fun assertFalse(condition: Bool) {
            if (condition) {
                throw new AssertException("Assertion failed: condition is true")
            }
        }

        static fun fail(message: String) {
            throw new AssertException("Assertion failed: $message")
        }

        static fun assertNotNull(value: Any?) {
            if (value == null) {
                throw new AssertException("Assertion failed: value is null")
            }
        }

        static fun assertNull(value: Any?) {
            if (value != null) {
                throw new AssertException("Assertion failed: value is not null")
            }
        }



    }
}